# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/wage_adjust
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================================
# AUTHENTICATION — REQUIRED: change before production
# ============================================================
# REQUIRED — must be changed before production.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOW_SELF_REGISTRATION=false

# ============================================================
# FILE STORAGE
# ============================================================
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BUCKET_NAME=wage-adjust-files

# ============================================================
# PII ENCRYPTION — REQUIRED: set before production
# ============================================================
# REQUIRED — must be set before production.
# Stores national ID numbers encrypted with AES-256-GCM.
# Generate: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# Leave empty to disable encryption (dev/test only — NOT safe for production).
NATIONAL_ID_ENCRYPTION_KEY=

# ============================================================
# AI / DEEPSEEK
# ============================================================
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1

# ============================================================
# CORS / APP
# ============================================================
APP_NAME=Wage Adjust Platform
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:5174", "http://127.0.0.1:5174"]

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# FEISHU / LARK OAUTH
# ============================================================
FEISHU_ENCRYPTION_KEY=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:5174/auth/feishu/callback
FEISHU_BIND_REDIRECT_URI=http://localhost:5174/settings/feishu-bind-callback

# ============================================================
# PUBLIC API — REQUIRED: change before production
# ============================================================
# REQUIRED — must be changed before production.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
PUBLIC_API_KEY=your_public_api_key
PUBLIC_API_RATE_LIMIT=1000/hour

# ============================================================
# ELIGIBILITY / PERFORMANCE THRESHOLDS
# ============================================================
# Eligibility 阈值（已在 backend/app/core/config.py 配置默认值）
# ELIGIBILITY_MIN_TENURE_MONTHS=6
# ELIGIBILITY_MIN_ADJUSTMENT_INTERVAL_MONTHS=6
# ELIGIBILITY_PERFORMANCE_FAIL_GRADES=C,D,E
# ELIGIBILITY_MAX_NON_STATUTORY_LEAVE_DAYS=30.0

# Performance tier engine 最小样本量（< 此值时引擎对全员返回 tier=null）
PERFORMANCE_TIER_MIN_SAMPLE_SIZE=50

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
