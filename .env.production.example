# ============================================================
# 运行环境 — 必填
# ============================================================
ENVIRONMENT=production
DEBUG=false

# ============================================================
# 数据库 — 必填，生产环境使用 PostgreSQL
# ============================================================
DATABASE_URL=postgresql://user:password@your-pg-host:5432/wage_adjust
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ============================================================
# 认证 — 必填，部署前必须修改
# ============================================================
# 必填 — 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOW_SELF_REGISTRATION=false

# ============================================================
# 文件存储 — 选填，默认使用本地 uploads/ 目录
# 如需 MinIO/S3，配置以下四项
# ============================================================
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BUCKET_NAME=wage-adjust-files
STORAGE_BASE_DIR=uploads
MAX_UPLOAD_SIZE_MB=200

# ============================================================
# PII 加密 — 必填，用于身份证号 AES-256-GCM 加密
# ============================================================
# 必填 — 生成方式: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
NATIONAL_ID_ENCRYPTION_KEY=

# ============================================================
# AI / DeepSeek — 必填
# ============================================================
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_VISION_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_PARSING_TIMEOUT_SECONDS=120
DEEPSEEK_EVALUATION_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_REQUESTS_PER_MINUTE=20
DEEPSEEK_REQUIRE_REAL_CALL_FOR_PARSING=true

# ============================================================
# CORS / 应用 — 按实际部署域名配置
# ============================================================
APP_NAME=Wage Adjust Platform
APP_VERSION=1.2.0
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://your-domain:8080"]

# ============================================================
# Redis — 必填，Celery 任务队列和缓存
# Docker 内部网络地址
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# 飞书集成 — 选填，用于考勤数据同步
# ============================================================
FEISHU_ENCRYPTION_KEY=

# ============================================================
# 公共 API — 必填，外部系统对接密钥
# ============================================================
# 必填 — 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
PUBLIC_API_KEY=
PUBLIC_API_RATE_LIMIT=1000/hour

# ============================================================
# 调薪资格阈值 — 选填，使用默认值即可
# ============================================================
ELIGIBILITY_MIN_TENURE_MONTHS=6
ELIGIBILITY_MIN_ADJUSTMENT_INTERVAL_MONTHS=6
ELIGIBILITY_PERFORMANCE_FAIL_GRADES=C,D,E
ELIGIBILITY_MAX_NON_STATUTORY_LEAVE_DAYS=30.0

# ============================================================
# 日志 — 选填
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
